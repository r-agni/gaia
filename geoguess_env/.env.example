# GeoGuessr Environment — copy to .env and fill in values

# HuggingFace API key (required for LLM agents + vision captioning)
HF_API_KEY=

# HuggingFace model for LLM agent (text)
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# HuggingFace model for vision captioning (street_view / globe_view)
VISION_MODEL_ID=meta-llama/Llama-3.2-11B-Vision-Instruct

# Google Maps API key (required for real Street View + Static Maps)
GOOGLE_MAPS_API_KEY=

# Environment server port
ENV_PORT=8001

# Base model for GRPO training
BASE_MODEL=Qwen/Qwen2.5-7B-Instruct

# vLLM server URL (for training in server mode)
VLLM_SERVER_URL=http://localhost:8000

# GeoGuessEnv WebSocket URL (for training rollout client)
GEOGUESS_ENV_URL=ws://localhost:8001

# Training output directory
OUTPUT_DIR=./geoguess-grpo-out

# Dataset path for training
DATASET_PATH=data/training_1k.jsonl

LOG_LEVEL=INFO
