# Copy this file to .env and fill in values

# HuggingFace Inference API key (get from https://huggingface.co/settings/tokens)
HF_API_KEY=hf_...

# Model to use for LLM agents (default: meta-llama/Llama-3.1-8B-Instruct)
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# Server port (default: 8001)
ENV_PORT=8001

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
